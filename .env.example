# Copy to .env and fill in. Never commit the real .env file.
# Get a free key: https://aistudio.google.com/apikey

# Streamlit app (config.py) reads this -> live mode instead of mock (unset = MOCK_MODE)
GEMINI_API_KEY=

# ADK path (adk web / adk run / adk_app) reads this one — use the SAME key value
GOOGLE_API_KEY=

# Tell ADK to use the AI Studio key, not Vertex AI / cloud
GOOGLE_GENAI_USE_VERTEXAI=FALSE

GEMINI_MODEL=gemini-2.5-flash
